import java.time.LocalDate;
import java.time.Period;
import java.time.format.DateTimeFormatter;

public class DateDemo {
    public static void main(String[] args) {
        DateTimeFormatter formatter = DateTimeFormatter.ofPattern("dd.MM.yyyy");
        
        LocalDate today = LocalDate.now();
        LocalDate birthDate = LocalDate.of(1995, 3, 15);
        
        Period age = Period.between(birthDate, today);
        int years = age.getYears();
        
        LocalDate nextBirthday = birthDate.withYear(today.getYear());
        if (nextBirthday.isBefore(today) || nextBirthday.isEqual(today)) {
            nextBirthday = nextBirthday.plusYears(1);
        }
        
        long daysUntilBirthday = Period.between(today, nextBirthday).getDays();
        
        System.out.println("Сегодня: " + today.format(formatter));
        System.out.println("Дата рождения: " + birthDate.format(formatter));
        System.out.println("Возраст: " + years + " лет");
        System.out.println("Дней до следующего дня рождения: " + daysUntilBirthday);
    }
}
